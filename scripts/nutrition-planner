def init_db():
    """初始化数据库"""
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 用户档案表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS user_profiles (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT,
            age INTEGER,
            gender TEXT,
            weight REAL,  -- kg
            height REAL,  -- cm
            activity_level TEXT,  -- sedentary, light, moderate, active
            goal TEXT,  -- lose, maintain, gain
            dietary_restrictions TEXT,  -- JSON array
            allergies TEXT,  -- JSON array
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')
    
    # 饮食计划表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS meal_plans (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date DATE,
            meal_type TEXT,  -- breakfast, lunch, dinner, snack
            recipe_name TEXT,
            items TEXT,  -- JSON
            total_calories REAL,
            total_protein REAL,
            total_carbs REAL,
            total_fat REAL,
            completed BOOLEAN DEFAULT 0
        )
    ''')
    
    # 购物清单表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS shopping_lists (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            week_start DATE,
            items TEXT,  -- JSON
            purchased TEXT  -- JSON array of purchased item names
        )
    ''')
    
    conn.commit()
    conn.close()

def calculate_bmr(weight: float, height: float, age: int, gender: str) -> float:
    """计算基础代谢率 (Mifflin-St Jeor 公式)"""
    if gender.lower() == 'male':
        return 10 * weight + 6.25 * height - 5 * age + 5
    else:
        return 10 * weight + 6.25 * height - 5 * age - 161

def calculate_tdee(bmr: float, activity_level: str) -> float:
    """计算每日总能量消耗"""
    multipliers = {
        'sedentary': 1.2,      # 久坐
        'light': 1.375,        # 轻度活动
        'moderate': 1.55,      # 中度活动
        'active': 1.725,       # 高度活动
        'very_active': 1.9     # 极高活动
    }
    return bmr * multipliers.get(activity_level, 1.2)

def get_target_calories(tdee: float, goal: str) -> float:
    """根据目标调整卡路里"""
    adjustments = {
        'lose': -500,      # 减脂
        'maintain': 0,     # 维持
        'gain': 500        # 增肌
    }
    return tdee + adjustments.get(goal, 0)

def calculate_recipe_nutrition(items: List[Tuple[str, float]]) -> Dict:
    """计算食谱营养信息"""
    total = {"calories": 0, "protein": 0, "carbs": 0, "fat": 0}
    
    for food_name, amount in items:
        # 查找食物
        nutrition = None
        for category, foods in FOOD_DATABASE.items():
            if food_name in foods:
                nutrition = foods[food_name]
                break
        
        if nutrition:
            ratio = amount / 100  # 转换为比例
            total["calories"] += nutrition["calories"] * ratio
            total["protein"] += nutrition["protein"] * ratio
            total["carbs"] += nutrition["carbs"] * ratio
            total["fat"] += nutrition["fat"] * ratio
    
    return total

def profile_create(args):
    """创建用户档案"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 计算营养需求
    bmr = calculate_bmr(args.weight, args.height, args.age, args.gender)
    tdee = calculate_tdee(bmr, args.activity)
    target_calories = get_target_calories(tdee, args.goal)
    
    # 保存档案
    cursor.execute('''
        INSERT INTO user_profiles 
        (name, age, gender, weight, height, activity_level, goal, dietary_restrictions, allergies)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    ''', (
        args.name, args.age, args.gender, args.weight, args.height,
        args.activity, args.goal,
        json.dumps(args.restrictions or []),
        json.dumps(args.allergies or [])
    ))
    
    conn.commit()
    conn.close()
    
    print(f"✅ 已创建用户档案: {args.name}")
    print()
    print("📊 营养分析:")
    print(f"   基础代谢率 (BMR): {bmr:.0f} kcal")
    print(f"   每日总消耗 (TDEE): {tdee:.0f} kcal")
    print(f"   目标摄入: {target_calories:.0f} kcal")
    print()
    print("🎯 目标:", {"lose": "减脂", "maintain": "维持", "gain": "增肌"}.get(args.goal, args.goal))

def profile_show(args):
    """显示用户档案"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM user_profiles ORDER BY id DESC LIMIT 1')
    profile = cursor.fetchone()
    conn.close()
    
    if not profile:
        print("ℹ️  暂无用户档案，请先创建")
        return
    
    _, name, age, gender, weight, height, activity, goal, restrictions, allergies, _ = profile
    
    # 计算营养需求
    bmr = calculate_bmr(weight, height, age, gender)
    tdee = calculate_tdee(bmr, activity)
    target_calories = get_target_calories(tdee, goal)
    
    print(f"👤 用户档案: {name}")
    print("=" * 40)
    print(f"   年龄: {age}岁")
    print(f"   性别: {'男' if gender == 'male' else '女'}")
    print(f"   身高: {height}cm")
    print(f"   体重: {weight}kg")
    print(f"   活动量: {activity}")
    print()
    print("📊 每日营养目标:")
    print(f"   目标热量: {target_calories:.0f} kcal")
    print(f"   建议蛋白质: {weight * 1.2:.0f}g - {weight * 2.0:.0f}g")
    print(f"   建议碳水: {(target_calories * 0.45 / 4):.0f}g - {(target_calories * 0.65 / 4):.0f}g")
    print(f"   建议脂肪: {(target_calories * 0.2 / 9):.0f}g - {(target_calories * 0.35 / 9):.0f}g")

def generate_daily_plan(target_calories: float, restrictions: List[str]) -> Dict:
    """生成每日饮食计划"""
    # 分配三餐热量比例
    breakfast_cal = target_calories * 0.3
    lunch_cal = target_calories * 0.4
    dinner_cal = target_calories * 0.25
    snack_cal = target_calories * 0.05
    
    plan = {}
    
    for meal_type, target in [("早餐", breakfast_cal), ("午餐", lunch_cal), 
                               ("晚餐", dinner_cal), ("加餐", snack_cal)]:
        key = {"早餐": "breakfast", "午餐": "lunch", "晚餐": "dinner", "加餐": "snack"}[meal_type]
        recipes = RECIPE_TEMPLATES.get(meal_type, [])
        
        # 选择最接近目标的食谱
        best_recipe = None
        best_diff = float('inf')
        
        for recipe in recipes:
            nutrition = calculate_recipe_nutrition(recipe["items"])
            diff = abs(nutrition["calories"] - target)
            if diff < best_diff:
                best_diff = diff
                best_recipe = recipe
        
        if best_recipe:
            nutrition = calculate_recipe_nutrition(best_recipe["items"])
            plan[key] = {
                "name": best_recipe["name"],
                "items": best_recipe["items"],
                "nutrition": nutrition,
                "tags": best_recipe.get("tags", [])
            }
    
    return plan

def plan_generate(args):
    """生成饮食计划"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 获取用户档案
    cursor.execute('SELECT weight, height, age, gender, activity_level, goal FROM user_profiles ORDER BY id DESC LIMIT 1')
    profile = cursor.fetchone()
    
    if not profile:
        print("❌ 请先创建用户档案: meal-planner profile-create")
        conn.close()
        return
    
    weight, height, age, gender, activity, goal = profile
    
    # 计算目标卡路里
    bmr = calculate_bmr(weight, height, age, gender)
    tdee = calculate_tdee(bmr, activity)
    target_calories = get_target_calories(tdee, goal)
    
    # 生成计划天数
    days = args.days or 7
    start_date = datetime.now().date()
    
    print(f"📅 生成 {days} 天饮食计划")
    print(f"🎯 目标热量: {target_calories:.0f} kcal/天")
    print()
    
    for day_offset in range(days):
        date = start_date + timedelta(days=day_offset)
        daily_plan = generate_daily_plan(target_calories, [])
        
        print(f"📆 {date} ({['周一','周二','周三','周四','周五','周六','周日'][date.weekday()]})")
        print("-" * 50)
        
        daily_total = {"calories": 0, "protein": 0, "carbs": 0, "fat": 0}
        
        for meal_key, meal_data in daily_plan.items():
            meal_name = {"breakfast": "早餐", "lunch": "午餐", "dinner": "晚餐", "snack": "加餐"}[meal_key]
            nutrition = meal_data["nutrition"]
            
            print(f"\n🍽️  {meal_name}: {meal_data['name']}")
            print(f"   标签: {', '.join(meal_data['tags'])}")
            print(f"   食材: {', '.join([f'{item[1]}g {item[0]}' for item in meal_data['items']])}")
            print(f"   热量: {nutrition['calories']:.0f} kcal | 蛋白质: {nutrition['protein']:.1f}g | 碳水: {nutrition['carbs']:.1f}g | 脂肪: {nutrition['fat']:.1f}g")
            
            # 累加
            for k in daily_total:
                daily_total[k] += nutrition[k]
            
            # 保存到数据库
            cursor.execute('''
                INSERT INTO meal_plans 
                (date, meal_type, recipe_name, items, total_calories, total_protein, total_carbs, total_fat)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ''', (
                date, meal_key, meal_data['name'], json.dumps(meal_data['items']),
                nutrition['calories'], nutrition['protein'], nutrition['carbs'], nutrition['fat']
            ))
        
        print(f"\n📊 当日总计: {daily_total['calories']:.0f} kcal | 蛋白质: {daily_total['protein']:.1f}g | 碳水: {daily_total['carbs']:.1f}g | 脂肪: {daily_total['fat']:.1f}g")
        print()
    
    conn.commit()
    conn.close()
    print(f"✅ 已生成并保存 {days} 天饮食计划")

def plan_show(args):
    """查看饮食计划"""
    date_str = args.date if hasattr(args, 'date') and args.date else datetime.now().strftime('%Y-%m-%d')
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT meal_type, recipe_name, items, total_calories, total_protein, total_carbs, total_fat
        FROM meal_plans WHERE date = ? ORDER BY 
        CASE meal_type 
            WHEN 'breakfast' THEN 1 
            WHEN 'lunch' THEN 2 
            WHEN 'dinner' THEN 3 
            WHEN 'snack' THEN 4 
        END
    ''', (date_str,))
    
    meals = cursor.fetchall()
    conn.close()
    
    if not meals:
        print(f"ℹ️  {date_str} 暂无饮食计划")
        return
    
    print(f"📅 {date_str} 饮食计划")
    print("=" * 50)
    
    daily_total = {"calories": 0, "protein": 0, "carbs": 0, "fat": 0}
    
    for meal_type, recipe_name, items_json, cal, pro, carb, fat in meals:
        meal_name = {"breakfast": "早餐", "lunch": "午餐", "dinner": "晚餐", "snack": "加餐"}[meal_type]
        items = json.loads(items_json)
        
        print(f"\n🍽️  {meal_name}: {recipe_name}")
        print(f"   食材: {', '.join([f'{item[1]}g {item[0]}' for item in items])}")
        print(f"   热量: {cal:.0f} kcal | 蛋白质: {pro:.1f}g | 碳水: {carb:.1f}g | 脂肪: {fat:.1f}g")
        
        daily_total["calories"] += cal
        daily_total["protein"] += pro
        daily_total["carbs"] += carb
        daily_total["fat"] += fat
    
    print(f"\n📊 当日总计: {daily_total['calories']:.0f} kcal | 蛋白质: {daily_total['protein']:.1f}g | 碳水: {daily_total['carbs']:.1f}g | 脂肪: {daily_total['fat']:.1f}g")

def shopping_list_generate(args):
    """生成购物清单"""
    days = args.days if hasattr(args, 'days') else 7
    start_date = datetime.now().date()
    end_date = start_date + timedelta(days=days)
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT items FROM meal_plans 
        WHERE date >= ? AND date < ?
    ''', (start_date, end_date))
    
    meals = cursor.fetchall()
    
    if not meals:
        print("ℹ️  请先生成饮食计划")
        conn.close()
        return
    
    # 汇总食材
    shopping_items = {}
    for (items_json,) in meals:
        items = json.loads(items_json)
        for food_name, amount in items:
            if food_name in shopping_items:
                shopping_items[food_name] += amount
            else:
                shopping_items[food_name] = amount
    
    conn.close()
    
    print(f"🛒 未来{days}天购物清单")
    print("=" * 40)
    
    # 按类别分组
    by_category = {}
    for food_name, amount in shopping_items.items():
        for category, foods in FOOD_DATABASE.items():
            if food_name in foods:
                if category not in by_category:
                    by_category[category] = []
                by_category[category].append((food_name, amount))
                break
    
    for category, items in by_category.items():
        print(f"\n📦 {category}:")
        for food_name, amount in sorted(items):
            print(f"   ☐ {food_name}: {amount:.0f}g")
    
    print(f"\n📊 共 {len(shopping_items)} 种食材")

def nutrition_query(args):
    """查询食物营养"""
    query = args.food.lower()
    
    print(f"🔍 查询: {args.food}")
    print("=" * 40)
    
    found = False
    for category, foods in FOOD_DATABASE.items():
        for food_name, nutrition in foods.items():
            if query in food_name.lower():
                found = True
                print(f"\n🍎 {food_name} ({category})")
                print(f"   热量: {nutrition['calories']} kcal/{nutrition['unit']}")
                print(f"   蛋白质: {nutrition['protein']}g")
                print(f"   碳水: {nutrition['carbs']}g")
                print(f"   脂肪: {nutrition['fat']}g")
    
    if not found:
        print(f"❌ 未找到 '{args.food}' 的营养信息")
        print("\n📋 可用食物:")
        for category, foods in FOOD_DATABASE.items():
            print(f"\n{category}: {', '.join(foods.keys())}")

def main():
    parser = argparse.ArgumentParser(
        prog='meal-planner',
        description='健康饮食规划师 - 个性化饮食计划工具',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
示例:
  meal-planner profile-create --name "张三" --age 30 --weight 70 --height 175 --goal lose
  meal-planner plan-generate --days 7
  meal-planner plan-show --date 2024-01-15
  meal-planner shopping-list --days 7
  meal-planner nutrition --food 鸡胸肉
        '''
    )
    
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    
    # 档案管理
    profile_parser = subparsers.add_parser('profile-create', help='创建用户档案')
    profile_parser.add_argument('--name', required=True, help='姓名')
    profile_parser.add_argument('--age', type=int, required=True, help='年龄')
    profile_parser.add_argument('--gender', choices=['male', 'female'], required=True, help='性别')
    profile_parser.add_argument('--weight', type=float, required=True, help='体重(kg)')
    profile_parser.add_argument('--height', type=float, required=True, help='身高(cm)')
    profile_parser.add_argument('--activity', choices=['sedentary', 'light', 'moderate', 'active', 'very_active'],
                               default='moderate', help='活动量')
    profile_parser.add_argument('--goal', choices=['lose', 'maintain', 'gain'], default='maintain', help='目标')
    profile_parser.add_argument('--restrictions', nargs='+', help='饮食限制')
    profile_parser.add_argument('--allergies', nargs='+', help='过敏食物')
    
    profile_show_parser = subparsers.add_parser('profile-show', help='显示用户档案')
    
    # 计划管理
    plan_gen_parser = subparsers.add_parser('plan-generate', help='生成饮食计划')
    plan_gen_parser.add_argument('--days', type=int, default=7, help='计划天数')
    
    plan_show_parser = subparsers.add_parser('plan-show', help='查看饮食计划')
    plan_show_parser.add_argument('--date', help='指定日期 (YYYY-MM-DD)')
    
    # 购物清单
    shopping_parser = subparsers.add_parser('shopping-list', help='生成购物清单')
    shopping_parser.add_argument('--days', type=int, default=7, help='天数')
    
    # 营养查询
    nutrition_parser = subparsers.add_parser('nutrition', help='查询食物营养')
    nutrition_parser.add_argument('food', help='食物名称')
    
    args = parser.parse_args()
    
    # 初始化数据库
    init_db()
    
    if args.command == 'profile-create':
        profile_create(args)
    elif args.command == 'profile-show':
        profile_show(args)
    elif args.command == 'plan-generate':
        plan_generate(args)
    elif args.command == 'plan-show':
        plan_show(args)
    elif args.command == 'shopping-list':
        shopping_list_generate(args)
    elif args.command == 'nutrition':
        nutrition_query(args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
